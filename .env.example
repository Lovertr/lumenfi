# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Encryption key for user AI API keys (generate with: openssl rand -base64 32)
APP_ENCRYPTION_KEY=replace-with-32-byte-base64-key

# N8N webhooks (set these after N8N setup)
N8N_WEBHOOK_RECURRING=https://your-n8n.example.com/webhook/recurring
N8N_WEBHOOK_OCR=https://your-n8n.example.com/webhook/ocr
N8N_WEBHOOK_DIGEST=https://your-n8n.example.com/webhook/digest

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=Finance App
